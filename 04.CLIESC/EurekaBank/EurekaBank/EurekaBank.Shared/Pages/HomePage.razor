@page "/home"

@inject SessionService SessionManager

<div class="dashboard-wrapper">
    @if (SessionManager.IsLoggedIn)
    {
        <div class="welcome-panel-modern mb-5">
            <div class="container-fluid">
                <div class="row justify-content-center">
                    <div class="col-12 col-lg-10 col-xl-8">
                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-4">
                            
                            <div class="d-flex align-items-center gap-4">
                                <div class="avatar-circle">
                                    <i class="fa-solid fa-user"></i>
                                </div>
                                <div>
                                    <h1 class="fw-bold mb-0" style="color: #0B56A4; font-size: 2rem;">¡Bienvenido!</h1>
                                    <p class="fs-5 mb-0 fw-semibold text-dark">@SessionManager.CurrentUser?.Nombre</p>
                                </div>
                            </div>

                            <div class="employee-glass">
                                <div class="glass-content d-flex align-items-center gap-3">
                                    <i class="fa-regular fa-id-badge fs-3" style="color: #64748B;"></i>
                                    <div>
                                        <span class="d-block text-uppercase fw-semibold" style="font-size: 0.75rem; color: #475569; letter-spacing: 0.5px;">Código de empleado</span>
                                        <strong class="fs-5 text-dark" style="font-weight: 800;">@SessionManager.CurrentUser?.Codigo</strong>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="mt-4">
                            <p style="color: #475569; font-size: 1.05rem;">
                                Gestiona tus operaciones bancarias de forma segura y eficiente desde tu panel de control.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-12 col-lg-10 col-xl-8">
                    <h2 class="fw-bold mb-4" style="color: #0B56A4; font-size: 1.3rem;">Acciones Rápidas</h2>
                    
                    <div class="row g-4 mb-5">
                        
                        <div class="col-12 col-md-4">
                            <a href="/transactions" class="action-card-modern card-tx">
                                <i class="fa-solid fa-arrow-right-arrow-left fs-4" style="color: #059669;"></i>
                                <div class="card-title-modern">Transacciones</div>
                                <div class="card-desc-modern">Depósitos, retiros y transferencias directas.</div>
                                <div class="action-link-modern">
                                    Ingresar <i class="fa-solid fa-arrow-right"></i>
                                </div>
                            </a>
                        </div>

                        <div class="col-12 col-md-4">
                            <a href="/reports" class="action-card-modern card-rep">
                                <i class="fa-solid fa-chart-column fs-4" style="color: #0284C7;"></i>
                                <div class="card-title-modern">Reportes</div>
                                <div class="card-desc-modern">Consulta movimientos y estados de cuenta.</div>
                                <div class="action-link-modern">
                                    Consultar <i class="fa-solid fa-arrow-right"></i>
                                </div>
                            </a>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="action-card-modern card-conf">
                                <i class="fa-solid fa-sliders fs-4" style="color: #64748B;"></i>
                                <div class="card-title-modern">Configuración</div>
                                <div class="card-desc-modern">Módulo próximamente disponible.</div>
                                <div class="action-link-modern" style="color: #64748B;">
                                    <i class="fa-solid fa-lock"></i> Bloqueado
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 70vh;">
            <i class="fa-solid fa-lock mb-3" style="font-size: 4rem; color: #CBD5E1;"></i>
            <h2 class="fw-bold" style="color: #0B56A4;">Acceso Denegado</h2>
            <p class="text-muted">Por favor inicia sesión para ver este panel.</p>
            <a href="/" class="btn btn-primary mt-3 px-4 rounded-pill" style="background-color: #0B56A4; border: none;">Iniciar Sesión</a>
        </div>
    }
</div>