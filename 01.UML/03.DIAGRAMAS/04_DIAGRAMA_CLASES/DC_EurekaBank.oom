<a:TemplateBody>    {
        try {
            Class.forName(DRIVER);
        } catch (ClassNotFoundException e) {
            throw new RuntimeException(&quot;Error al cargar el driver de MySQL: &quot; + e.getMessage(), e);
        }
    }
</a:TemplateBody>
