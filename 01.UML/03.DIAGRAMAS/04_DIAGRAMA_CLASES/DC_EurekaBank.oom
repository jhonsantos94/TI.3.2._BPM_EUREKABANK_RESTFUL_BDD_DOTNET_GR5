<o:Operation Id="o114">
<a:ObjectID>322A0BA4-DD9B-4D56-AE1F-8E09DCA6AA80</a:ObjectID>
<a:Name>obtenerPorCodigo</a:Name>
<a:Code>obtenerPorCodigo</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Obtiene una cuenta por su código
</a:Comment>
<a:ReturnType>Cuenta</a:ReturnType>
<a:Operation.Throws>SQLException</a:Operation.Throws>
<a:TemplateBody>{
    String sql = &quot;SELECT chr_cuencodigo, chr_monecodigo, chr_sucucodigo, &quot;
            + &quot;chr_emplcreacuenta, chr_cliecodigo, dec_cuensaldo, &quot;
            + &quot;dtt_cuenfechacreacion, vch_cuenestado, int_cuencontmov, chr_cuenclave &quot;
            + &quot;FROM cuenta WHERE chr_cuencodigo = ?&quot;;

    try (Connection conn = ConexionDB.getConnection();
         PreparedStatement ps = conn.prepareStatement(sql)) {

        ps.setString(1, codigo);
        ResultSet rs = ps.executeQuery();

        if (rs.next()) {
            return mapearCuenta(rs);
        }
        return null;
    }
}
</a:TemplateBody>
