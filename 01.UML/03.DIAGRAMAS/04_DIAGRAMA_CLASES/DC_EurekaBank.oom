<a:Comment>DAO para operaciones con la tabla Cliente
</a:Comment>
<a:UseParentNamespace>0</a:UseParentNamespace>
<a:Classifier.Header> </a:Classifier.Header>
<a:Imports>import ec.edu.monster.db.ConexionDB;
import ec.edu.monster.models.Cliente;
import java.sql.*;
import java.util.ArrayList;
import java.util.List;
</a:Imports>
<c:Operations>
<o:Operation Id="o101">
<a:ObjectID>03C6B364-82EB-4D33-ACEC-C9FAF3005D68</a:ObjectID>
<a:Name>obtenerTodos</a:Name>
<a:Code>obtenerTodos</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Obtiene todos los clientes
</a:Comment>
<a:ReturnType>List&lt;Cliente&gt;</a:ReturnType>
<a:Operation.Throws>SQLException</a:Operation.Throws>
<a:TemplateBody>{
    String sql = &quot;SELECT chr_cliecodigo, vch_cliepaterno, vch_cliematerno, vch_clienombre, &quot;
            + &quot;chr_cliedni, vch_clieciudad, vch_cliedireccion, vch_clietelefono, vch_clieemail &quot;
            + &quot;FROM cliente ORDER BY vch_cliepaterno, vch_cliematerno, vch_clienombre&quot;;

    List&lt;Cliente&gt; clientes = new ArrayList&lt;&gt;();

    try (Connection conn = ConexionDB.getConnection();
         PreparedStatement ps = conn.prepareStatement(sql);
         ResultSet rs = ps.executeQuery()) {

        while (rs.next()) {
            clientes.add(mapearCliente(rs));
        }
    }

    return clientes;
}
</a:TemplateBody>
</o:Operation>
<o:Operation Id="o102">
<a:ObjectID>C85DF20B-80CD-43A1-946D-3D074EF5DA23</a:ObjectID>
<a:Name>obtenerPorCodigo</a:Name>
<a:Code>obtenerPorCodigo</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Obtiene un cliente por su código
</a:Comment>
<a:ReturnType>Cliente</a:ReturnType>
<a:Operation.Throws>SQLException</a:Operation.Throws>
<a:TemplateBody>{
    String sql = &quot;SELECT chr_cliecodigo, vch_cliepaterno, vch_cliematerno, vch_clienombre, &quot;
            + &quot;chr_cliedni, vch_clieciudad, vch_cliedireccion, vch_clietelefono, vch_clieemail &quot;
            + &quot;FROM cliente WHERE chr_cliecodigo = ?&quot;;

    try (Connection conn = ConexionDB.getConnection();
         PreparedStatement ps = conn.prepareStatement(sql)) {

        ps.setString(1, codigo);
        ResultSet rs = ps.executeQuery();

        if (rs.next()) {
            return mapearCliente(rs);
        }
        return null;
    }
}
</a:TemplateBody>
