<o:Operation Id="o183">
<a:ObjectID>676355B9-76CC-4732-87C9-61283956BE32</a:ObjectID>
<a:Name>getConnection</a:Name>
<a:Code>getConnection</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>/**
     * Carga el driver JDBC de MySQL
     */
Crea y retorna una nueva conexión a la base de datos MySQL
</a:Comment>
<a:ReturnType>Connection</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:Operation.Throws>SQLException</a:Operation.Throws>
<a:TemplateBody>{
    try {
        Connection conn = DriverManager.getConnection(URL, USUARIO, CLAVE);
        return conn;
    } catch (SQLException e) {
        throw new SQLException(&quot;Error al conectar con la base de datos: &quot; + e.getMessage(), e);
    }
}
</a:TemplateBody>
<a:ExtendedAttributesText>{0DEDDB90-46E2-45A0-886E-411709DA0DC9},Java,195={1D4C2EF4-615A-4148-85BD-47ECAC4BD1CC},Javadoc@return,30=@return Connection configurada
{F03653A9-9917-45E2-8F4E-2713C1F58F40},Javadoc@throws,47=@throws SQLException si hay error al conectar


</a:ExtendedAttributesText>
</o:Operation>
<o:Operation Id="o184">
<a:ObjectID>E59320B1-AD5E-45C3-B5B7-0A27C3337B39</a:ObjectID>
<a:Name>obtenerConexion</a:Name>
<a:Code>obtenerConexion</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Obtiene una conexión a la base de datos (alias para compatibilidad)
</a:Comment>
<a:ReturnType>Connection</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:Operation.Throws>SQLException</a:Operation.Throws>
<a:TemplateBody>{
    return getConnection();
}
</a:TemplateBody>
<a:ExtendedAttributesText>{0DEDDB90-46E2-45A0-886E-411709DA0DC9},Java,195={1D4C2EF4-615A-4148-85BD-47ECAC4BD1CC},Javadoc@return,30=@return Connection configurada
{F03653A9-9917-45E2-8F4E-2713C1F58F40},Javadoc@throws,47=@throws SQLException si hay error al conectar


</a:ExtendedAttributesText>
</o:Operation>
<o:Operation Id="o185">
<a:ObjectID>F7D2EEDF-0CA8-49EB-B29E-5E0D017AE265</a:ObjectID>
<a:Name>probarConexion</a:Name>
<a:Code>probarConexion</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Prueba la conexión a la base de datos
</a:Comment>
<a:ReturnType>boolean</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    try (Connection conn = getConnection()) {
        return conn != null &amp;&amp; !conn.isClosed();
    } catch (SQLException e) {
        System.err.println(&quot;Error al probar conexión: &quot; + e.getMessage());
        return false;
    }
}
</a:TemplateBody>
<a:ExtendedAttributesText>{0DEDDB90-46E2-45A0-886E-411709DA0DC9},Java,124={1D4C2EF4-615A-4148-85BD-47ECAC4BD1CC},Javadoc@return,65=@return true si la conexión es exitosa, false en caso contrario


</a:ExtendedAttributesText>
</o:Operation>
<o:Operation Id="o186">
<a:ObjectID>E504B46C-AC52-41FC-8330-0605F5BAE214</a:ObjectID>
<a:Name>cerrarConexion</a:Name>
<a:Code>cerrarConexion</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Cierra la conexión de forma segura
</a:Comment>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    if (conn != null) {
        try {
            if (!conn.isClosed()) {
                conn.close();
            }
        } catch (SQLException e) {
            System.err.println(&quot;Error al cerrar conexión: &quot; + e.getMessage());
        }
    }
}
</a:TemplateBody>
