<o:Operation Id="o145">
<a:ObjectID>CD38003A-4F00-4545-BE37-9CA5AD35C7AD</a:ObjectID>
<a:Name>actualizarClave</a:Name>
<a:Code>actualizarClave</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Actualiza la clave de un empleado
</a:Comment>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Throws>SQLException</a:Operation.Throws>
<a:TemplateBody>{
    String sql = &quot;UPDATE empleado SET vch_emplclave = ? WHERE chr_emplcodigo = ?&quot;;

    try (Connection conn = ConexionDB.getConnection();
         PreparedStatement ps = conn.prepareStatement(sql)) {

        ps.setString(1, claveNueva);
        ps.setString(2, codigoEmpleado);
        ps.executeUpdate();
    }
}
</a:TemplateBody>
