<o:Operation Id="o143">
<a:ObjectID>AFD26D8A-5A42-4264-B102-23CB0AE60CB1</a:ObjectID>
<a:Name>registrar</a:Name>
<a:Code>registrar</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Registra un nuevo empleado con usuario y clave
</a:Comment>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Throws>SQLException</a:Operation.Throws>
<a:TemplateBody>{
    String sql = &quot;INSERT INTO empleado (chr_emplcodigo, vch_emplpaterno, &quot;
            + &quot;vch_emplmaterno, vch_emplnombre, vch_emplciudad, vch_empldireccion, &quot;
            + &quot;vch_emplusuario, vch_emplclave) &quot;
            + &quot;VALUES (?, ?, ?, ?, ?, ?, ?, ?)&quot;;

    try (Connection conn = ConexionDB.getConnection();
         PreparedStatement ps = conn.prepareStatement(sql)) {

        ps.setString(1, empleado.getCodigo());
        ps.setString(2, empleado.getPaterno());
        ps.setString(3, empleado.getMaterno());
        ps.setString(4, empleado.getNombre());
        ps.setString(5, empleado.getCiudad());
        ps.setString(6, empleado.getDireccion());
        ps.setString(7, empleado.getUsuario());
        ps.setString(8, empleado.getClave());
        ps.executeUpdate();
    }
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o144">
