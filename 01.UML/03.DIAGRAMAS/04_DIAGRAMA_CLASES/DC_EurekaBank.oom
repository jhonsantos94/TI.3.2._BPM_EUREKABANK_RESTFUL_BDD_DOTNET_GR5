<o:Class Id="o848">
<a:ObjectID>3F3F3440-2CA3-4D4E-8C53-A5669551313C</a:ObjectID>
<a:Name>CuentaValidator</a:Name>
<a:Code>CuentaValidator</a:Code>
<a:CreationDate>1779067881</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067881</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Validador para operaciones relacionadas con cuentas
</a:Comment>
<a:UseParentNamespace>0</a:UseParentNamespace>
<a:Classifier.Header> </a:Classifier.Header>
<a:Imports>import ec.edu.monster.constants.EstadosConstants;
import ec.edu.monster.constants.MensajesConstants;
import ec.edu.monster.models.Cuenta;
import java.math.BigDecimal;
</a:Imports>
<c:Operations>
<o:Operation Id="o853">
<a:ObjectID>6CAA5B6D-4D66-4FF2-86B6-20B34CDABE83</a:ObjectID>
<a:Name>validarExistencia</a:Name>
<a:Code>validarExistencia</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Valida que la cuenta exista
</a:Comment>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:Operation.Throws>Exception</a:Operation.Throws>
<a:TemplateBody>{
    if (cuenta == null) {
        throw new Exception(MensajesConstants.CUENTA_NO_EXISTE);
    }
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o854">
<a:ObjectID>0F33393D-DB45-4290-B1E1-B2F09A8352F1</a:ObjectID>
<a:Name>cuenta</a:Name>
<a:Code>cuenta</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Parameter.DataType>Cuenta</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
</o:Operation>
<o:Operation Id="o855">
<a:ObjectID>3085FBA1-4048-427B-8BFE-021C54C9A931</a:ObjectID>
<a:Name>validarEstadoActivo</a:Name>
<a:Code>validarEstadoActivo</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Valida que la cuenta esté activa
</a:Comment>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:Operation.Throws>Exception</a:Operation.Throws>
<a:TemplateBody>{
    if (!EstadosConstants.ACTIVO.equals(cuenta.getEstado())) {
        throw new Exception(MensajesConstants.CUENTA_INACTIVA);
    }
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o856">
<a:ObjectID>A6E321F6-4E14-4BD8-B8EA-65C7FDF59360</a:ObjectID>
