<o:Operation Id="o889">
<a:ObjectID>3FE71286-B270-4621-BA21-5E4EFB172765</a:ObjectID>
<a:Name>validarDatosEmpleado</a:Name>
<a:Code>validarDatosEmpleado</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Valida los datos completos de un empleado
</a:Comment>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:Operation.Throws>Exception</a:Operation.Throws>
<a:TemplateBody>{
    if (empleado == null) {
        throw new Exception(MensajesConstants.DATOS_INCOMPLETOS);
    }

    if (empleado.getPaterno() == null || empleado.getPaterno().trim().isEmpty()) {
        throw new Exception(&quot;El apellido paterno es obligatorio&quot;);
    }

    if (empleado.getMaterno() == null || empleado.getMaterno().trim().isEmpty()) {
        throw new Exception(&quot;El apellido materno es obligatorio&quot;);
    }

    if (empleado.getNombre() == null || empleado.getNombre().trim().isEmpty()) {
        throw new Exception(&quot;El nombre es obligatorio&quot;);
    }

    if (empleado.getCiudad() == null || empleado.getCiudad().trim().isEmpty()) {
        throw new Exception(&quot;La ciudad es obligatoria&quot;);
    }
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o890">
<a:ObjectID>1CBB42FB-EDCC-4DB3-A752-ACDDFEA343C8</a:ObjectID>
<a:Name>empleado</a:Name>
<a:Code>empleado</a:Code>
