<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Parameter.DataType>String</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
</o:Operation>
<o:Operation Id="o909">
<a:ObjectID>DED2CBA2-42FB-4DC4-B2C5-77EC9A2B81A2</a:ObjectID>
<a:Name>debeAplicarCargoMantenimiento</a:Name>
<a:Code>debeAplicarCargoMantenimiento</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Determina si se debe aplicar cargo por mantenimiento
</a:Comment>
<a:ReturnType>boolean</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    BigDecimal montoMinimo = obtenerMontoMinimo(cuenta.getCodigoMoneda());
    return cuenta.getSaldo().compareTo(montoMinimo) &lt; 0;
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o910">
<a:ObjectID>057F956D-28CA-4DFB-888D-FE4EBE088BA6</a:ObjectID>
