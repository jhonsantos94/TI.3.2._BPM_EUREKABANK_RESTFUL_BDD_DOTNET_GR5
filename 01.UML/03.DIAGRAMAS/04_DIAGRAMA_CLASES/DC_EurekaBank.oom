<o:Operation Id="o907">
<a:ObjectID>3F58EDA6-2937-4BF4-B05D-C38A8B4A4506</a:ObjectID>
<a:Name>obtenerMontoMinimo</a:Name>
<a:Code>obtenerMontoMinimo</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Obtiene el monto mínimo para evitar cargo de mantenimiento
</a:Comment>
<a:ReturnType>BigDecimal</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    if (CostosConstants.MONEDA_SOLES.equals(codigoMoneda)) {
        return CostosConstants.MONTO_MINIMO_SOLES;
    } else if (CostosConstants.MONEDA_DOLARES.equals(codigoMoneda)) {
        return CostosConstants.MONTO_MINIMO_DOLARES;
    }
    return BigDecimal.ZERO;
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o908">
<a:ObjectID>B3FFF146-6F46-40C4-8635-0E1278B64492</a:ObjectID>
<a:Name>codigoMoneda</a:Name>
<a:Code>codigoMoneda</a:Code>
