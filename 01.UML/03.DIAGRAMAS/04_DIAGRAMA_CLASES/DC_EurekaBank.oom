<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Parameter.DataType>Empleado</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
</o:Operation>
<o:Operation Id="o891">
<a:ObjectID>FB39E03D-9646-4331-9C72-86E4EF45A3D4</a:ObjectID>
<a:Name>validarDatosRegistro</a:Name>
<a:Code>validarDatosRegistro</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Valida los datos para registro de empleado con usuario
</a:Comment>
<a:ReturnType>void</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:Operation.Throws>Exception</a:Operation.Throws>
<a:TemplateBody>{
    validarDatosEmpleado(empleado);

    if (empleado.getUsuario() != null &amp;&amp; !empleado.getUsuario().trim().isEmpty()) {
        validarUsuario(empleado.getUsuario());
        validarClave(empleado.getClave());
    }
}
</a:TemplateBody>
