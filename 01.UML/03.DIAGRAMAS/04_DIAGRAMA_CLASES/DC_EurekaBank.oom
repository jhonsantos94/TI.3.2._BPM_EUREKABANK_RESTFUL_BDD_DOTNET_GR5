<o:Class Id="o852">
<a:ObjectID>622A5C7B-D509-461D-827A-B60115E11247</a:ObjectID>
<a:Name>TransaccionValidator</a:Name>
<a:Code>TransaccionValidator</a:Code>
<a:CreationDate>1779067881</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067881</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Validador y calculador para operaciones de transacciones
</a:Comment>
<a:UseParentNamespace>0</a:UseParentNamespace>
<a:Classifier.Header> </a:Classifier.Header>
<a:Imports>import ec.edu.monster.constants.CostosConstants;
import ec.edu.monster.models.Cuenta;
import java.math.BigDecimal;
import java.math.RoundingMode;
</a:Imports>
<c:Operations>
<o:Operation Id="o894">
<a:ObjectID>AF14D0E0-EBA4-4CF2-9063-A9513D17343D</a:ObjectID>
<a:Name>calcularITF</a:Name>
<a:Code>calcularITF</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Calcula el ITF (Impuesto a las Transacciones Financieras)
ITF = Importe * 0.0008 (0.08%)
</a:Comment>
<a:ReturnType>BigDecimal</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    BigDecimal itf = importe.multiply(CostosConstants.TASA_ITF);
    return itf.setScale(2, RoundingMode.HALF_UP);
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o895">
<a:ObjectID>9E0982CD-F83F-4745-B0A0-5B24C9EBCE84</a:ObjectID>
<a:Name>importe</a:Name>
<a:Code>importe</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Parameter.DataType>BigDecimal</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
</o:Operation>
<o:Operation Id="o896">
<a:ObjectID>6B9F6296-4FF4-47A1-B633-AE9138E60A21</a:ObjectID>
<a:Name>debeAplicarCargoMovimiento</a:Name>
<a:Code>debeAplicarCargoMovimiento</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Determina si se debe aplicar cargo por movimiento adicional
Se cobra si la cuenta ha realizado más de 15 movimientos
</a:Comment>
<a:ReturnType>boolean</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    return cuenta.getContadorMovimientos() &gt;= CostosConstants.OPERACIONES_GRATUITAS;
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o897">
<a:ObjectID>A5170F68-0F14-440A-BB2E-864BC44F55E6</a:ObjectID>
<a:Name>cuenta</a:Name>
<a:Code>cuenta</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Parameter.DataType>Cuenta</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
</o:Operation>
<o:Operation Id="o898">
<a:ObjectID>E0650E3B-6F62-4B7A-AB28-1CD5DB8B19B4</a:ObjectID>
<a:Name>obtenerCargoMovimiento</a:Name>
<a:Code>obtenerCargoMovimiento</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Obtiene el importe del cargo por movimiento según la moneda
</a:Comment>
<a:ReturnType>BigDecimal</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    if (CostosConstants.MONEDA_SOLES.equals(codigoMoneda)) {
        return CostosConstants.COSTO_MOVIMIENTO_SOLES;
    } else if (CostosConstants.MONEDA_DOLARES.equals(codigoMoneda)) {
        return CostosConstants.COSTO_MOVIMIENTO_DOLARES;
    }
    return BigDecimal.ZERO;
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o899">
<a:ObjectID>0ADA622F-4816-455E-970C-F740927C0E32</a:ObjectID>
<a:Name>codigoMoneda</a:Name>
<a:Code>codigoMoneda</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Parameter.DataType>String</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
</o:Operation>
<o:Operation Id="o900">
<a:ObjectID>5F763AD8-4669-4A02-85CD-58A14AAF190C</a:ObjectID>
<a:Name>calcularCargoMovimiento</a:Name>
<a:Code>calcularCargoMovimiento</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Calcula el cargo por movimiento si aplica
</a:Comment>
<a:ReturnType>BigDecimal</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    if (debeAplicarCargoMovimiento(cuenta)) {
        return obtenerCargoMovimiento(cuenta.getCodigoMoneda());
    }
    return BigDecimal.ZERO;
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o901">
<a:ObjectID>3A41F7C5-334B-4D03-9802-5CA6C4642AE9</a:ObjectID>
<a:Name>cuenta</a:Name>
<a:Code>cuenta</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Parameter.DataType>Cuenta</a:Parameter.DataType>
</o:Parameter>
</c:Parameters>
</o:Operation>
<o:Operation Id="o902">
<a:ObjectID>2E0FB0EC-D6EA-4FFD-9391-61674F5D29DD</a:ObjectID>
<a:Name>calcularTotalRetiro</a:Name>
<a:Code>calcularTotalRetiro</a:Code>
<a:CreationDate>1779067883</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067883</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Comment>Calcula el total a descontar en un retiro (importe + ITF + cargo)
</a:Comment>
<a:ReturnType>BigDecimal</a:ReturnType>
<a:Operation.Static>1</a:Operation.Static>
<a:TemplateBody>{
    BigDecimal itf = calcularITF(importeRetiro);
    BigDecimal cargo = calcularCargoMovimiento(cuenta);

    return importeRetiro.add(itf).add(cargo);
}
</a:TemplateBody>
<c:Parameters>
<o:Parameter Id="o903">
<a:ObjectID>F21903ED-BD53-4523-8219-7EA12157DAAD</a:ObjectID>
<a:Name>importeRetiro</a:Name>
