<a:ObjectID>0069E6BD-2B1B-40E9-8BC7-7608AAB9E453</a:ObjectID>
<a:Name>_STATIC_INITIALIZER</a:Name>
<a:Code>_STATIC_INITIALIZER</a:Code>
<a:CreationDate>1779067882</a:CreationDate>
<a:Creator>Jhon Santos</a:Creator>
<a:ModificationDate>1779067882</a:ModificationDate>
<a:Modifier>Jhon Santos</a:Modifier>
<a:Stereotype>staticInitializer</a:Stereotype>
